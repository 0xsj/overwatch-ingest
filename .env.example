# Server
INGEST_SERVER_HOST=0.0.0.0
INGEST_SERVER_PORT=50054
INGEST_SERVER_ENABLE_REFLECTION=true
INGEST_SERVER_ENABLE_HEALTH_CHECK=true
INGEST_SERVER_SHUTDOWN_TIMEOUT=30s

# Database
INGEST_DATABASE_HOST=localhost
INGEST_DATABASE_PORT=5451
INGEST_DATABASE_USER=overwatch
INGEST_DATABASE_PASSWORD=overwatch
INGEST_DATABASE_NAME=overwatch_ingest
INGEST_DATABASE_SSL_MODE=disable
INGEST_DATABASE_MAX_CONNS=25
INGEST_DATABASE_MIN_CONNS=5
INGEST_DATABASE_MAX_CONN_LIFETIME=1h
INGEST_DATABASE_MAX_CONN_IDLE_TIME=30m
INGEST_DATABASE_HEALTH_CHECK_PERIOD=1m

# NATS
INGEST_NATS_URL=nats://localhost:4230
INGEST_NATS_SUBJECT_PREFIX=overwatch.ingest
INGEST_NATS_MAX_RECONNECTS=10
INGEST_NATS_RECONNECT_WAIT=2s

# Service Identity
INGEST_SERVICE_IDENTITY_ID=ingest-service
INGEST_SERVICE_IDENTITY_NAME=ingest
INGEST_SERVICE_IDENTITY_PRIVATE_KEY_PATH=
INGEST_SERVICE_IDENTITY_PRIVATE_KEY=
INGEST_SERVICE_IDENTITY_GENERATE_IF_MISSING=true

# Ingest Thresholds
INGEST_ACCEPT_THRESHOLD=0.7
INGEST_REJECT_THRESHOLD=0.3
INGEST_QUARANTINE_EXPIRY=72h
INGEST_RELIABILITY_QUARANTINE_THRESHOLD=0.4
INGEST_MIN_RELIABILITY_RECORDS=10
INGEST_REQUIRE_COLLECTOR_SIGNATURE=true
INGEST_REQUIRE_SOURCE_SIGNATURE=false